rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Aplica a regra para todas as coleções (connections, contacts, messages)
    // Permite leitura e escrita APENAS se o 'userId' do documento
    // for igual ao ID do usuário autenticado (request.auth.uid).
    match /{collection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
